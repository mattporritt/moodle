{{!
    @template tiny_aiplacement/modal

    Modal to manage ai content within the Tiny Editor.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * elementid: The id of the element that will be used to create the modal.
    * modaltitle: The title of the modal.

    Example context (json):
    {
        "elementid": "exampleId",
        "modaltitle": "Generate AI Image"
    }
}}
{{< core/modal }}

    {{$title}}
        {{modaltitle}}
    {{/title}}

    {{$body}}
        <div id="{{elementid}}_tiny_aiplacement_spinner" class="hidden">
            <div class="tiny-aiplacement-loading-spinner d-flex justify-content-center align-items-center flex-column">
                <div class="spinner-border tiny-aiplacement-spinner-style" role="status">
                    <span class="sr-only">Loading...</span>
                </div>
                <div id="{{elementid}}_tiny_aiplacement_loading_text" class="text-center tiny-aiplacement-spinner-text-style">
                    Loading...
                </div>
            </div>
        </div>
        <div id="{{elementid}}_tiny_aiplacement_blur" class="">
            <div id="{{elementid}}_tiny_aiplacement_overlay" class="tiny-aiplacement-overlay hidden"></div>
            <form class="mform" id="{{uniqid}}">
                <div class="form-group">
                    <label for="{{elementid}}_tiny_aiplacement_prompttext">
                        {{#str}} prompttext_label, tiny_aiplacement {{/str}}
                    </label>
                    <textarea
                            class="form-control"
                            id="{{elementid}}_tiny_aiplacement_prompttext"
                            rows="3"
                            placeholder="{{#str}} prompttext_placeholder, tiny_aiplacement {{/str}}"></textarea>
                    <label for="{{elementid}}_tiny_aiplacement_responsetext">
                        {{#str}} responsetext_label, tiny_aiplacement {{/str}}
                    </label>
                    <textarea
                            class="form-control"
                            id="{{elementid}}_tiny_aiplacement_responsetext"
                            rows="3"
                            placeholder="{{#str}} responsetext_placeholder, tiny_aiplacement {{/str}}"
                            disabled="disabled"></textarea>
                </div>
            </form>
        </div>
    {{/body}}

    {{$footer}}
        <button type="button"
                class="btn btn-secondary"
                data-action="cancel">
            {{#str}} cancel, moodle {{/str}}
        </button>
        <button id="{{elementid}}_tiny_aiplacement_generatebutton"
                type="button"
                class="btn btn-primary"
                data-action="generate"
                disabled="disabled">
            {{#str}} generate, tiny_aiplacement{{/str}}
        </button>
        <button id="{{elementid}}_tiny_aiplacement_insertbutton"
                type="button"
                class="btn btn-primary hidden"
                data-action="inserter">
            {{#str}} insert, tiny_aiplacement{{/str}}
        </button>
    {{/footer}}

{{/ core/modal }}
